# CTI E-Commerce Platform - Environment Configuration
# Container Port: Different from local PostgreSQL to avoid conflicts

# =================================================================
# DATABASE CONFIGURATION (Docker Container)
# =================================================================
# Using port 5433 to avoid conflicts with local PostgreSQL (usually 5432)
DB_PORT=5433
POSTGRES_USER=cti_user
POSTGRES_PASSWORD=cti_password_dev
POSTGRES_DB=cti_ecommerce

# =================================================================
# BACKEND CONFIGURATION
# =================================================================
NODE_ENV=development
BACKEND_PORT=3000
DATABASE_URL=postgresql://cti_user:cti_password_dev@localhost:5433/cti_ecommerce?schema=public

# =================================================================
# FRONTEND CONFIGURATION
# =================================================================
FRONTEND_PORT=5173

# =================================================================
# NOTES
# =================================================================
# - DB_PORT=5433 maps container port 5432 to host port 5433
# - If local PostgreSQL is running on 5432, no conflict will occur
# - Prisma will connect to localhost:5433
# - To verify: psql -U cti_user -h localhost -p 5433 -d cti_ecommerce
